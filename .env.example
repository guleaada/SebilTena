# --- Database (Turso / libSQL) ---
# Leave TURSO_DATABASE_URL empty for local dev: the app falls back to a local
# SQLite file at ./medaguard.db automatically.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Server ---
PORT=3000
# Deployment posture (Milestone 8). NODE_ENV=production hardens the app and runs
# the fail-closed preflight; with unreviewed first-aid a cleared production build
# REFUSES TO START. STAGING=true = a clearly-labelled DEMONSTRATION build: still
# hardened (preflight enforced) but boots with unreviewed first-aid + shows the
# non-dismissible demonstration banner. Never set reviewed:true to force a boot.
NODE_ENV=
STAGING=

# --- AI routing (used from Milestone 2 onward) ---
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# --- SMS fallback: Africa's Talking (Milestone 5) ---
AT_API_KEY=
AT_USERNAME=
AT_SHORTCODE=
# Shared secret guarding POST /api/sms/webhook. If set, inbound posts must send
# it as ?secret= or the x-webhook-secret header. LEAVE SET IN PRODUCTION.
AT_WEBHOOK_SECRET=
# Optional SMS tunables (defaults shown)
SMS_RATE_LIMIT_PER_HOUR=20
SMS_SESSION_TTL_MIN=30
SMS_INBOUND_MAX_CHARS=160
# Real national poison-information line (shown in emergency replies).
POISON_CENTRE_NUMBER=

# --- Admin surveillance map (Milestone 7) ---
ADMIN_TOKEN=

# --- Write-side anti-abuse (Milestone 7.5) ---
# HMAC secret for the opaque, PII-free write token (anti-abuse, NOT identity).
# SET IN PRODUCTION so tokens survive restarts and span instances; if unset a
# random per-process secret is used (dev only — clients just re-register).
DEVICE_TOKEN_SECRET=
DEVICE_TOKEN_TTL_DAYS=7
# Rate limits on the WRITE/REGISTER surface only (verdict + emergency never throttled).
DEVICE_REG_PER_HOUR_PER_IP=10
SYNC_SCANS_PER_HOUR_PER_TOKEN=60
SYNC_CALLS_PER_HOUR_PER_IP=120
SYNC_MAX_BATCH=200
