# --- Database (Turso / libSQL) ---
# Leave TURSO_DATABASE_URL empty for local dev: the app falls back to a local
# SQLite file at ./medaguard.db automatically.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Server ---
PORT=3000

# --- AI routing (used from Milestone 2 onward) ---
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# --- SMS fallback: Africa's Talking (Milestone 5) ---
AT_API_KEY=
AT_USERNAME=
AT_SHORTCODE=
# Shared secret guarding POST /api/sms/webhook. If set, inbound posts must send
# it as ?secret= or the x-webhook-secret header. LEAVE SET IN PRODUCTION.
AT_WEBHOOK_SECRET=
# Optional SMS tunables (defaults shown)
SMS_RATE_LIMIT_PER_HOUR=20
SMS_SESSION_TTL_MIN=30
SMS_INBOUND_MAX_CHARS=160
# Real national poison-information line (shown in emergency replies).
POISON_CENTRE_NUMBER=

# --- Admin surveillance map (Milestone 7) ---
ADMIN_TOKEN=
